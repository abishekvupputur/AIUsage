<Window x:Class="CopilotUsage.Views.UsagePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudeAI Usage"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <Style x:Key="UsageProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="#D4845A"/>
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CopilotBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource UsageProgressBarStyle}">
            <Setter Property="Foreground" Value="#3FB950"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsageColorZone}" Value="Yellow">
                    <Setter Property="Foreground" Value="#D4A72C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageColorZone}" Value="Red">
                    <Setter Property="Foreground" Value="#F47067"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WeeklyBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource UsageProgressBarStyle}">
            <Setter Property="Foreground" Value="#3FB950"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding WeeklyColorZone}" Value="Yellow">
                    <Setter Property="Foreground" Value="#D4A72C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding WeeklyColorZone}" Value="Red">
                    <Setter Property="Foreground" Value="#F47067"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExtraBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource UsageProgressBarStyle}">
            <Setter Property="Foreground" Value="#3FB950"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ExtraColorZone}" Value="Yellow">
                    <Setter Property="Foreground" Value="#D4A72C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ExtraColorZone}" Value="Red">
                    <Setter Property="Foreground" Value="#F47067"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Gemini bucket row template (shared between single list and tabs) -->
        <DataTemplate x:Key="GeminiBucketTemplate">
            <StackPanel Margin="0,0,0,10">
                <DockPanel Margin="0,0,0,4">
                    <TextBlock Text="{Binding DisplayName}" FontSize="11" Foreground="#C0C0C0"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding ResetTimeSummary}" FontSize="10" Foreground="#888888"
                               HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </DockPanel>
                <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100" Height="6"
                             Background="#2E2E2E" BorderThickness="0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar" BasedOn="{StaticResource UsageProgressBarStyle}">
                            <Setter Property="Foreground" Value="#3FB950"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ColorZone}" Value="Yellow">
                                    <Setter Property="Foreground" Value="#D4A72C"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ColorZone}" Value="Red">
                                    <Setter Property="Foreground" Value="#F47067"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
                <TextBlock Text="{Binding RemainingPercentSummary}" FontSize="11" Foreground="#AAAAAA"
                           Margin="0,3,0,0" HorizontalAlignment="Right" FontFamily="Segoe UI"/>
            </StackPanel>
        </DataTemplate>

        <!-- Dark TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Background="Transparent" Margin="0,0,0,8"/>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Tab" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <TextBlock x:Name="Lbl" Text="{TemplateBinding Header}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#D4845A"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#1A1A1A"/>
                                <Setter TargetName="Lbl" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Tab" Property="Background" Value="#2E2E2E"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#EBEBEB"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider toggle: active -->
        <Style x:Key="ProvBtnActiveStyle" TargetType="Button">
            <Setter Property="Background" Value="#D4845A"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider toggle: inactive -->
        <Style x:Key="ProvBtnInactiveStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2E2E2E"/>
                                <Setter Property="Foreground" Value="#EBEBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button: transparent bg, subtle dark rounded hover -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2E2E2E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A1A"
            BorderBrush="#333333"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8,14,16,14"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel Width="300" TextElement.FontFamily="Segoe UI">

            <!-- Header -->
            <DockPanel Margin="8,0,0,12">
                <!-- Close -->
                <Button DockPanel.Dock="Right" Content="✕" Width="22" Height="22"
                        Style="{StaticResource IconButtonStyle}"
                        FontSize="11" Foreground="#666666"
                        Click="CloseButton_Click"
                        VerticalAlignment="Center"/>
                <!-- Refresh -->
                <Button x:Name="RefreshButton" DockPanel.Dock="Right"
                        Width="22" Height="22" Margin="0,0,2,0"
                        Style="{StaticResource IconButtonStyle}"
                        VerticalAlignment="Center"
                        Click="RefreshButton_Click"
                        ToolTip="Refresh now">
                    <Viewbox Width="13" Height="13">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="#D4845A" StrokeThickness="2.2" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 20,12 A 8,8 0 1 1 16.5,5.1"/>
                            <Polygon Points="14,2 18,6 13,7" Fill="#D4845A"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <!-- Provider toggle buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ClaudeProviderBtn" Content="Claude" Margin="0,0,4,0"
                            Click="ClaudeProvider_Click"/>
                    <Button x:Name="CopilotProviderBtn" Content="Copilot" Margin="0,0,4,0"
                            Click="CopilotProvider_Click"/>
                    <Button x:Name="OpenAIProviderBtn" Content="OpenAI" Margin="0,0,4,0"
                            Click="OpenAIProvider_Click"/>
                    <Button x:Name="GeminiProviderBtn" Content="Gemini"
                            Click="GeminiProvider_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- Error panel -->
            <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#2C1A1A" BorderBrush="#5A2A2A" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                           Foreground="#F47067" FontSize="11" FontFamily="Segoe UI"/>
            </Border>

            <!-- Cat (left) + Bars (right) -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cat column -->
                <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="{Binding CatImageSource}"
                           Width="96" Height="96"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           SnapsToDevicePixels="True"/>
                    <TextBlock Text="{Binding CatStateLabel}" FontSize="10" Foreground="#888888"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               FontFamily="Segoe UI" Margin="0,0,0,2"/>
                </Grid>

                <!-- Bars column -->
                <StackPanel Grid.Column="2">

                    <!-- Gemini: simplified 3-bar view (>4 buckets, similar usage across types) -->
                    <ItemsControl ItemsSource="{Binding GeminiSimplifiedBuckets}"
                                  ItemTemplate="{StaticResource GeminiBucketTemplate}"
                                  Visibility="{Binding ShowGeminiSimplified, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Gemini: single list (≤ 4 models, or V2Only/V3Only filter) -->
                    <ItemsControl ItemsSource="{Binding GeminiBucketsFiltered}"
                                  ItemTemplate="{StaticResource GeminiBucketTemplate}"
                                  Visibility="{Binding ShowGeminiSingleList, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Gemini: tabbed view (> 4 models) -->
                    <TabControl Visibility="{Binding ShowGeminiTabs, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TabItem Header="Gemini 2.x">
                            <ItemsControl ItemsSource="{Binding GeminiV2Buckets}"
                                          ItemTemplate="{StaticResource GeminiBucketTemplate}"/>
                        </TabItem>
                        <TabItem Header="Gemini 3.x">
                            <ItemsControl ItemsSource="{Binding GeminiV3Buckets}"
                                          ItemTemplate="{StaticResource GeminiBucketTemplate}"/>
                        </TabItem>
                    </TabControl>

                    <!-- Standard bars (Claude / GitHub Copilot) — hidden for Gemini -->
                    <StackPanel Visibility="{Binding ShowStandardBars, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- Current Session bar -->
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock Text="{Binding SessionBarLabel}" FontSize="11" Foreground="#C0C0C0"
                                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding ResetAtSummary}" FontSize="10" Foreground="#888888"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </DockPanel>
                        <ProgressBar Style="{StaticResource CopilotBarStyle}"
                                     Value="{Binding UsagePercent, Mode=OneWay}"/>
                        <TextBlock Text="{Binding UsageSummary}" FontSize="11" Foreground="#AAAAAA"
                                   Margin="0,4,0,12" HorizontalAlignment="Right" FontFamily="Segoe UI"/>

                        <!-- Weekly Usage bar -->
                        <StackPanel Visibility="{Binding ShowWeeklyBar, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Text="{Binding MonthProgressLabel}" FontSize="11" Foreground="#C0C0C0"
                                           VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding WeeklyResetSummary}" FontSize="10" Foreground="#888888"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                            </DockPanel>
                            <ProgressBar Style="{StaticResource WeeklyBarStyle}"
                                         Value="{Binding MonthProgressPercent, Mode=OneWay}"/>
                            <TextBlock Text="{Binding MonthProgressSummary}" FontSize="11" Foreground="#AAAAAA"
                                       Margin="0,4,0,12" HorizontalAlignment="Right" FontFamily="Segoe UI"/>
                        </StackPanel>

                        <!-- Extra Usage bar (pay-per-use credits) -->
                        <StackPanel Visibility="{Binding ExtraUsageEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Text="Extra Usage (monthly)" FontSize="11" Foreground="#C0C0C0"
                                           VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                <TextBlock Text="Pay-per-use" FontSize="10" Foreground="#888888"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                            </DockPanel>
                            <ProgressBar Style="{StaticResource ExtraBarStyle}"
                                         Value="{Binding ExtraPercent, Mode=OneWay}"/>
                            <TextBlock Text="{Binding ExtraSummary}" FontSize="11" Foreground="#AAAAAA"
                                       Margin="0,4,0,12" HorizontalAlignment="Right" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Grid>

            <!-- Footer -->
            <Separator Margin="0,0,0,8" Background="#2E2E2E" BorderBrush="#2E2E2E"/>

            <!-- Demo mode banner — only visible when IsDemoMode=true -->
            <Border Visibility="{Binding IsDemoMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#2A2010" BorderBrush="#4A3A10" BorderThickness="1"
                    CornerRadius="4" Padding="6,3" Margin="0,0,0,6">
                <TextBlock Text="⚙ DEMO MODE — cycling through test scenarios"
                           FontSize="10" Foreground="#D4A72C" TextAlignment="Center" FontFamily="Segoe UI"/>
            </Border>

            <DockPanel>
                <!-- Right-side content must be declared first so DockPanel.Dock="Right" takes effect -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- Spinning arc — rotated by code-behind DispatcherTimer only while IsLoading=true -->
                    <Canvas Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" CenterX="5" CenterY="5"/>
                        </Canvas.RenderTransform>
                        <Path Stroke="#D4845A" StrokeThickness="1.5" Data="M 5,0.5 A 4.5,4.5 0 0 1 9.5,5"/>
                    </Canvas>
                    <TextBlock Text="{Binding LastUpdatedSummary}" FontSize="10" Foreground="#888888"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </StackPanel>
            </DockPanel>

        </StackPanel>
    </Border>
</Window>
