<Window x:Class="CopilotUsage.Views.UsagePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Usage"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <Style x:Key="UsageProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="#28A745"/>
            <Setter Property="Background" Value="#E9ECEF"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CopilotBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource UsageProgressBarStyle}">
            <Setter Property="Foreground" Value="#28A745"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsageColorZone}" Value="Yellow">
                    <Setter Property="Foreground" Value="#FFC107"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageColorZone}" Value="Red">
                    <Setter Property="Foreground" Value="#DC3545"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MonthBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource UsageProgressBarStyle}">
            <Setter Property="Foreground" Value="#0D6EFD"/>
        </Style>
    </Window.Resources>

    <Border Background="White"
            BorderBrush="#CED4DA"
            BorderThickness="1"
            CornerRadius="6"
            Padding="16,12,16,14"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#888888" BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <StackPanel Width="300">

            <!-- Header -->
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="Copilot Usage" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="✕" Width="22" Height="22"
                        Background="Transparent" BorderThickness="0" FontSize="12"
                        Foreground="#6C757D" Cursor="Hand"
                        Click="CloseButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Error panel -->
            <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                           Foreground="#664D03" FontSize="11"/>
            </Border>

            <!-- Premium Requests bar -->
            <TextBlock Text="Premium Requests" FontSize="11" Foreground="#495057" Margin="0,0,0,4"/>
            <ProgressBar Style="{StaticResource CopilotBarStyle}"
                         Value="{Binding UsagePercent, Mode=OneWay}"/>
            <TextBlock Text="{Binding UsageSummary}" FontSize="11" Foreground="#6C757D"
                       Margin="0,3,0,10" HorizontalAlignment="Right"/>

            <!-- Month Progress bar — label is a single bound string, no extra spaces -->
            <TextBlock Text="{Binding MonthProgressLabel}" FontSize="11" Foreground="#495057" Margin="0,0,0,4"/>
            <ProgressBar Style="{StaticResource MonthBarStyle}"
                         Value="{Binding MonthProgressPercent, Mode=OneWay}"/>
            <TextBlock Text="{Binding MonthProgressSummary}" FontSize="11" Foreground="#6C757D"
                       Margin="0,3,0,10" HorizontalAlignment="Right"/>

            <!-- Footer: reset date | [spinner] last-updated -->
            <Separator Margin="0,0,0,8"/>

            <!-- Demo mode banner — only visible when IsDemoMode=true -->
            <Border Visibility="{Binding IsDemoMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1"
                    CornerRadius="4" Padding="6,3" Margin="0,0,0,6">
                <TextBlock Text="⚙ DEMO MODE — cycling through test scenarios"
                           FontSize="10" Foreground="#664D03" TextAlignment="Center"/>
            </Border>

            <DockPanel>
                <!-- Right-side content must be declared first so DockPanel.Dock="Right" takes effect -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- Spinning arc — rotated by code-behind DispatcherTimer only while IsLoading=true -->
                    <Canvas Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" CenterX="5" CenterY="5"/>
                        </Canvas.RenderTransform>
                        <Path Stroke="#ADB5BD" StrokeThickness="1.5" Data="M 5,0.5 A 4.5,4.5 0 0 1 9.5,5"/>
                    </Canvas>
                    <TextBlock Text="{Binding LastUpdatedSummary}" FontSize="10" Foreground="#ADB5BD" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding ResetAtSummary}" FontSize="10" Foreground="#ADB5BD" VerticalAlignment="Center"/>
            </DockPanel>

        </StackPanel>
    </Border>
</Window>
