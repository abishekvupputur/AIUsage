<Window x:Class="CopilotUsage.Views.RawJsonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raw API Response"
        Width="600" Height="500"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#1A1A1A"
        Foreground="#EBEBEB">

    <Window.Resources>
        <Style x:Key="ProviderActiveStyle" TargetType="Button">
            <Setter Property="Background" Value="#D4845A"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProviderInactiveStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#EBEBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CopyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D4845A"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C07348"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16" TextElement.FontFamily="Segoe UI">

        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="Copy" Width="60" Padding="0,4"
                    Style="{StaticResource CopyButtonStyle}"
                    Click="CopyButton_Click"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ClaudeBtn"  Content="Claude"  Margin="0,0,6,0"
                        Tag="Claude"  Click="ProviderBtn_Click"/>
                <Button x:Name="CopilotBtn" Content="Copilot" Margin="0,0,6,0"
                        Tag="Copilot" Click="ProviderBtn_Click"/>
                <Button x:Name="OpenAIBtn"  Content="OpenAI"  Margin="0,0,6,0"
                        Tag="OpenAI"  Click="ProviderBtn_Click"/>
                <Button x:Name="GeminiBtn"  Content="Gemini"
                        Tag="Gemini"  Click="ProviderBtn_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Loading / error banner -->
        <Border x:Name="StatusBanner" DockPanel.Dock="Top"
                Background="#2C1A1A" BorderBrush="#5A2A2A" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap"
                       Foreground="#F47067" FontSize="11"/>
        </Border>

        <!-- JSON text area -->
        <Border Background="#111111" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="5"/>
                        <Setter Property="Height" Value="5"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Width="0" Height="0"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="Bg" Background="#3A3A3A" CornerRadius="3"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="Background" Value="#555555"/>
                                                                </Trigger>
                                                                <Trigger Property="IsDragging" Value="True">
                                                                    <Setter TargetName="Bg" Property="Background" Value="#D4845A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Width="0" Height="0"/>
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <TextBox x:Name="JsonTextBox"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12"
                         Foreground="#EBEBEB" Background="Transparent"
                         BorderThickness="0" Padding="10"
                         TextWrapping="NoWrap"
                         VerticalAlignment="Top"
                         Text="Fetching…"/>
            </ScrollViewer>
        </Border>

    </DockPanel>
</Window>
