<Window x:Class="CopilotUsage.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Usage - Settings"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#1A1A1A"
        Foreground="#EBEBEB">

    <Window.Resources>
        <!-- Dark PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="CaretBrush" Value="#D4845A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionBrush" Value="#D4845A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="CaretBrush" Value="#D4845A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionBrush" Value="#D4845A"/>
        </Style>
        <!-- Dark ComboBox with full template -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#252525"/>
                        <Setter Property="Foreground" Value="#EBEBEB"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A2A1A"/>
                                <Setter Property="Foreground" Value="#D4845A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Right"
                                                  Width="22" Background="Transparent" BorderThickness="0"
                                                  Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                                </DockPanel>
                            </Border>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder"
                                    Width="14" Height="14"
                                    Background="#252525" BorderBrush="#555555" BorderThickness="1"
                                    CornerRadius="2" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 2 6 L 5 10 L 12 2"
                                      Stroke="#D4845A" StrokeThickness="1.8"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D4845A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D4845A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Accent Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D4845A"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C07348"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A86038"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Ghost/secondary Button -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider tab control -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent" Margin="4,6,4,0"/>
                            </Border>
                            <Border Grid.Row="1" Background="#222222" BorderBrush="#333333" BorderThickness="1,0,1,1">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Provider tab item -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Tab" Background="{TemplateBinding Background}"
                                CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <TextBlock x:Name="Lbl" Text="{TemplateBinding Header}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tab" Property="Background" Value="#D4845A"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#1A1A1A"/>
                                <Setter TargetName="Lbl" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Tab" Property="Background" Value="#2E2E2E"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#EBEBEB"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" TextElement.FontFamily="Segoe UI">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Provider tabs ── -->
        <TabControl Grid.Row="0" Margin="0,0,0,14" MinHeight="340">

            <!-- Claude AI -->
            <TabItem x:Name="ClaudeTab" Header="Claude AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14,12">
                        <CheckBox x:Name="ClaudeEnableCheck" Content="Show in tray application"
                                  IsEnabled="False" Margin="0,0,0,8"/>
                        <Separator Margin="0,0,0,12" Background="#333333" BorderBrush="#333333"/>
                        <TextBlock Text="Claude Session Key" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#EBEBEB" Margin="0,0,0,10"/>

                        <TextBlock Text="How to get your session key:" FontWeight="SemiBold"
                                   FontSize="12" Foreground="#EBEBEB" Margin="0,0,0,6"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3">
                                <Run Text="1.  Open "/>
                                <Run Text="claude.ai" FontWeight="SemiBold" Foreground="#D4845A"/>
                                <Run Text=" in your browser and sign in"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3">
                                <Run Text="2.  Press "/>
                                <Run Text="F12" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                                <Run Text="  →  Application  →  Cookies  →  https://claude.ai"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3">
                                <Run Text="3.  Find the row named "/>
                                <Run Text="sessionKey" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                                <Run Text=" and double-click its Value cell"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="#888888">
                                <Run Text="4.  Press "/>
                                <Run Text="Ctrl+A" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                                <Run Text=" to select all, then "/>
                                <Run Text="Ctrl+C" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                                <Run Text=" to copy — the value is very long"/>
                            </TextBlock>
                        </StackPanel>

                        <DockPanel Margin="0,0,0,5">
                            <TextBlock Text="Session Key:" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#EBEBEB" VerticalAlignment="Center"/>
                            <TextBlock x:Name="KeyLengthHint" DockPanel.Dock="Right"
                                       FontSize="11" Foreground="#555555" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SessionKeyBox"
                                     Grid.Column="0"
                                     FontFamily="Cascadia Code, Consolas" FontSize="11"
                                     Padding="7,6" Margin="0,0,8,0"
                                     TextWrapping="NoWrap"
                                     VerticalContentAlignment="Center"
                                     MaxLength="4000"
                                     TextChanged="SessionKeyBox_TextChanged"/>
                            <Button x:Name="TestButton"
                                    Grid.Column="1"
                                    Content="Test"
                                    Width="70" Padding="0,6"
                                    Click="TestButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="AuthStatusText"
                                   Text="" TextWrapping="Wrap"
                                   FontSize="12" Margin="0,8,0,0"
                                   Foreground="#888888"
                                   Visibility="Collapsed"/>

                        <Separator Margin="0,12,0,8" Background="#333333" BorderBrush="#333333"/>
                        <DockPanel>
                            <TextBlock Text="Refresh interval:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ClaudeIntervalCombo" Width="120" HorizontalAlignment="Right" FontSize="11">
                                <ComboBoxItem Content="1 minute"   Tag="1"/>
                                <ComboBoxItem Content="5 minutes"  Tag="5"/>
                                <ComboBoxItem Content="15 minutes" Tag="15"/>
                                <ComboBoxItem Content="30 minutes" Tag="30"/>
                                <ComboBoxItem Content="60 minutes" Tag="60"/>
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- GitHub Copilot -->
            <TabItem x:Name="CopilotTab" Header="GitHub Copilot">
                <StackPanel Margin="14,12">
                    <CheckBox x:Name="CopilotEnableCheck" Content="Show in tray application"
                              IsEnabled="False" Margin="0,0,0,8"/>
                    <Separator Margin="0,0,0,12" Background="#333333" BorderBrush="#333333"/>
                    <TextBlock Text="GitHub Copilot Auth" FontWeight="SemiBold"
                               FontSize="13" Foreground="#EBEBEB" Margin="0,0,0,10"/>

                    <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,12" TextWrapping="Wrap">
                        Sign in with GitHub to grant access to your Copilot usage data.
                        Click Connect and follow the instructions in your browser.
                    </TextBlock>

                    <!-- Connected state -->
                    <StackPanel x:Name="CopilotConnectedPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock x:Name="CopilotConnectedText" FontSize="12" Foreground="#3FB950"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="CopilotDisconnectButton" Content="Disconnect"
                                Width="110" HorizontalAlignment="Left" Padding="0,6"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="CopilotDisconnect_Click"/>
                    </StackPanel>

                    <!-- Device code flow -->
                    <StackPanel x:Name="CopilotAuthFlowPanel">
                        <Button x:Name="CopilotConnectButton" Content="Connect GitHub Account"
                                Width="180" HorizontalAlignment="Left" Padding="0,6"
                                Click="CopilotConnect_Click"/>

                        <StackPanel x:Name="CopilotDeviceCodePanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,6" TextWrapping="Wrap">
                                Open the URL below and enter the code to authorise:
                            </TextBlock>
                            <TextBlock x:Name="CopilotVerificationUrl" FontSize="12" Foreground="#D4845A"
                                       Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                            <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,4">Your code:</TextBlock>
                            <TextBlock x:Name="CopilotUserCode" FontSize="20" FontWeight="Bold"
                                       Foreground="#EBEBEB" FontFamily="Cascadia Code, Consolas"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="CopilotCancelButton" Content="Cancel"
                                    Width="80" HorizontalAlignment="Left" Padding="0,6"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Click="CopilotCancel_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="CopilotStatusText"
                               Text="" TextWrapping="Wrap"
                               FontSize="12" Margin="0,8,0,0"
                               Foreground="#888888"
                               Visibility="Collapsed"/>

                    <Separator Margin="0,12,0,8" Background="#333333" BorderBrush="#333333"/>
                    <DockPanel>
                        <TextBlock Text="Refresh interval:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CopilotIntervalCombo" Width="120" HorizontalAlignment="Right" FontSize="11">
                            <ComboBoxItem Content="1 minute"   Tag="1"/>
                            <ComboBoxItem Content="5 minutes"  Tag="5"/>
                            <ComboBoxItem Content="15 minutes" Tag="15"/>
                            <ComboBoxItem Content="30 minutes" Tag="30"/>
                            <ComboBoxItem Content="60 minutes" Tag="60"/>
                        </ComboBox>
                    </DockPanel>
                </StackPanel>
            </TabItem>

            <!-- OpenAI Codex -->
            <TabItem x:Name="OpenAITab" Header="OpenAI Codex">
                <StackPanel Margin="14,12">
                    <CheckBox x:Name="OpenAIEnableCheck" Content="Show in tray application"
                              IsEnabled="False" Margin="0,0,0,8"/>
                    <Separator Margin="0,0,0,12" Background="#333333" BorderBrush="#333333"/>
                    <TextBlock Text="OpenAI Codex Auth" FontWeight="SemiBold"
                               FontSize="13" Foreground="#EBEBEB" Margin="0,0,0,10"/>

                    <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,12" TextWrapping="Wrap">
                        Sign in with your OpenAI/ChatGPT account to access your Codex subscription limits.
                        Note: This is separate from OpenAI Platform (API) credits.
                    </TextBlock>

                    <!-- Connected state -->
                    <StackPanel x:Name="OpenAIConnectedPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock x:Name="OpenAIConnectedText" FontSize="12" Foreground="#3FB950"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="OpenAIDisconnectButton" Content="Disconnect"
                                Width="110" HorizontalAlignment="Left" Padding="0,6"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="OpenAIDisconnect_Click"/>
                    </StackPanel>

                    <!-- Device code flow -->
                    <StackPanel x:Name="OpenAIAuthFlowPanel">
                        <Button x:Name="OpenAIConnectButton" Content="Connect OpenAI Account"
                                Width="180" HorizontalAlignment="Left" Padding="0,6"
                                Click="OpenAIConnect_Click"/>

                        <StackPanel x:Name="OpenAIDeviceCodePanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,6" TextWrapping="Wrap">
                                Open the URL below and enter the code to authorise:
                            </TextBlock>
                            <TextBlock x:Name="OpenAIVerificationUrl" FontSize="12" Foreground="#D4845A"
                                       Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                            <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,4">Your code:</TextBlock>
                            <TextBlock x:Name="OpenAIUserCode" FontSize="20" FontWeight="Bold"
                                       Foreground="#EBEBEB" FontFamily="Cascadia Code, Consolas"
                                       Margin="0,0,0,8"/>
                            <Button x:Name="OpenAICancelButton" Content="Cancel"
                                    Width="80" HorizontalAlignment="Left" Padding="0,6"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Click="OpenAICancel_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="OpenAIStatusText"
                               Text="" TextWrapping="Wrap"
                               FontSize="12" Margin="0,8,0,0"
                               Foreground="#888888"
                               Visibility="Collapsed"/>

                    <Separator Margin="0,12,0,8" Background="#333333" BorderBrush="#333333"/>
                    <DockPanel>
                        <TextBlock Text="Refresh interval:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                        <ComboBox x:Name="OpenAIIntervalCombo" Width="120" HorizontalAlignment="Right" FontSize="11">
                            <ComboBoxItem Content="1 minute"   Tag="1"/>
                            <ComboBoxItem Content="5 minutes"  Tag="5"/>
                            <ComboBoxItem Content="15 minutes" Tag="15"/>
                            <ComboBoxItem Content="30 minutes" Tag="30"/>
                            <ComboBoxItem Content="60 minutes" Tag="60"/>
                        </ComboBox>
                    </DockPanel>
                </StackPanel>
            </TabItem>

            <!-- Gemini -->
            <TabItem x:Name="GeminiTab" Header="Gemini">
                <StackPanel Margin="14,12">
                    <CheckBox x:Name="GeminiEnableCheck" Content="Show in tray application"
                              IsEnabled="False" Margin="0,0,0,8"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Display:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                        <ComboBox x:Name="GeminiDisplayModeCombo" Width="220" HorizontalAlignment="Right" FontSize="11">
                            <ComboBoxItem Content="Auto (simplify when usage is similar)" Tag="Auto"/>
                            <ComboBoxItem Content="Simplified (always 3 bars)"            Tag="Simplified"/>
                            <ComboBoxItem Content="All models (tabbed by version)"         Tag="All"/>
                            <ComboBoxItem Content="Gemini 2.x only"                        Tag="V2Only"/>
                            <ComboBoxItem Content="Gemini 3.x only"                        Tag="V3Only"/>
                        </ComboBox>
                    </DockPanel>
                    <Separator Margin="0,0,0,12" Background="#333333" BorderBrush="#333333"/>
                    <TextBlock Text="Gemini Auth" FontWeight="SemiBold"
                               FontSize="13" Foreground="#EBEBEB" Margin="0,0,0,10"/>

                    <TextBlock Text="How to set up:" FontWeight="SemiBold"
                               FontSize="12" Foreground="#EBEBEB" Margin="0,0,0,6"/>

                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10"
                                  Padding="0,0,6,0">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="5"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="Transparent">
                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Height="0"/>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border x:Name="Bg" Background="#3A3A3A" CornerRadius="3"/>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="#555555"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsDragging" Value="True">
                                                                            <Setter TargetName="Bg" Property="Background" Value="#D4845A"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Height="0"/>
                                                    </Track.IncreaseRepeatButton>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ScrollViewer.Resources>
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#D4845A" Margin="0,0,0,4">Step 1 — Find Client ID and Secret</TextBlock>
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3" TextWrapping="Wrap">
                                On any PC with <Run FontWeight="SemiBold" Foreground="#EBEBEB">gemini-cli</Run> installed via npm, run in PowerShell:
                            </TextBlock>
                            <Border Background="#181818" CornerRadius="3" Padding="7,5" Margin="0,0,0,3">
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"
                                           xml:space="preserve">$npmGlobal = npm root -g
Select-String "OAUTH_CLIENT_ID|OAUTH_CLIENT_SECRET" `
  "$npmGlobal\@google\gemini-cli\bundle\chunk-*.js" `
  | Select-Object -First 4</TextBlock>
                            </Border>
                            <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,10" TextWrapping="Wrap">
                                Copy the two values from the output.
                            </TextBlock>

                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#D4845A" Margin="0,0,0,4">Step 2 — Get Refresh Token</TextBlock>
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3" TextWrapping="Wrap">
                                Run <Run FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB">gemini</Run> once to log in, then extract the token:
                            </TextBlock>
                            <Border Background="#181818" CornerRadius="3" Padding="7,5" Margin="0,0,0,3">
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"
                                           xml:space="preserve">gemini   # log in, then Ctrl+C

$creds = Get-Content "$env:USERPROFILE\.gemini\oauth_creds.json" | ConvertFrom-Json
$creds.refresh_token   # copy this value</TextBlock>
                            </Border>
                            <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,10" TextWrapping="Wrap">
                                Token is tied to your Google account, not the machine. Treat it like a password.
                            </TextBlock>

                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#D4845A" Margin="0,0,0,4">Step 3 — Creds file on this PC</TextBlock>
                            <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3" TextWrapping="Wrap">
                                If <Run FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB">gemini-cli</Run> is installed here,
                                <Run FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB">%USERPROFILE%\.gemini\oauth_creds.json</Run> already exists — use it directly.
                                Otherwise create it manually:
                            </TextBlock>
                            <Border Background="#181818" CornerRadius="3" Padding="7,5" Margin="0,0,0,3">
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap"
                                           xml:space="preserve">New-Item -ItemType Directory -Force "$env:USERPROFILE\.gemini"

@{ refresh_token = "PASTE_TOKEN_HERE" } `
  | ConvertTo-Json `
  | Set-Content "$env:USERPROFILE\.gemini\oauth_creds.json"</TextBlock>
                            </Border>

                            <Border Background="#1E1A10" BorderBrush="#4A3A10" BorderThickness="1"
                                    CornerRadius="3" Padding="7,6" Margin="0,6,0,2">
                                <TextBlock FontSize="11" Foreground="#D4A72C" TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold">Note:</Run>
                                    <Run>Refresh token invalidates if you revoke access at</Run>
                                    <Run FontFamily="Cascadia Code, Consolas" Foreground="#EBEBEB">myaccount.google.com → Security → Third-party apps → Gemini CLI</Run>
                                    <Run>. Re-run Step 2 after re-authorising.</Run>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Separator Margin="0,0,0,12" Background="#2E2E2E" BorderBrush="#2E2E2E"/>

                    <TextBlock Text="Client ID:" FontSize="12" FontWeight="SemiBold"
                               Foreground="#EBEBEB" Margin="0,0,0,4"/>
                    <TextBox x:Name="GeminiClientIdBox"
                             Padding="7,6" Margin="0,0,0,10"
                             FontFamily="Cascadia Code, Consolas" FontSize="11"/>

                    <TextBlock Text="Client Secret:" FontSize="12" FontWeight="SemiBold"
                               Foreground="#EBEBEB" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="GeminiClientSecretBox"
                                 Padding="7,6" Margin="0,0,0,10"
                                 FontFamily="Cascadia Code, Consolas" FontSize="11"/>

                    <TextBlock Text="Credentials file path:" FontSize="12" FontWeight="SemiBold"
                               Foreground="#EBEBEB" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="GeminiCredPathBox"
                                 Grid.Column="0"
                                 Padding="7,6" Margin="0,0,8,0"
                                 FontFamily="Cascadia Code, Consolas" FontSize="11"/>
                        <Button x:Name="GeminiBrowseButton"
                                Grid.Column="1"
                                Content="Browse…" Width="80" Padding="0,6"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="GeminiBrowse_Click"/>
                    </Grid>

                    <Button x:Name="GeminiTestButton"
                            Content="Test Connection"
                            Width="140" HorizontalAlignment="Left" Padding="0,6"
                            Click="GeminiTest_Click"/>

                    <TextBlock x:Name="GeminiStatusText"
                               Text="" TextWrapping="Wrap"
                               FontSize="12" Margin="0,8,0,0"
                               Foreground="#888888"
                               Visibility="Collapsed"/>

                    <Separator Margin="0,12,0,8" Background="#333333" BorderBrush="#333333"/>
                    <DockPanel>
                        <TextBlock Text="Refresh interval:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                        <ComboBox x:Name="GeminiIntervalCombo" Width="120" HorizontalAlignment="Right" FontSize="11">
                            <ComboBoxItem Content="1 minute"   Tag="1"/>
                            <ComboBoxItem Content="5 minutes"  Tag="5"/>
                            <ComboBoxItem Content="15 minutes" Tag="15"/>
                            <ComboBoxItem Content="30 minutes" Tag="30"/>
                            <ComboBoxItem Content="60 minutes" Tag="60"/>
                        </ComboBox>
                    </DockPanel>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- Separator -->
        <Separator Grid.Row="1" Margin="0,0,0,14" Background="#2E2E2E" BorderBrush="#2E2E2E"/>

        <!-- Start with Windows -->
        <CheckBox x:Name="StartupCheckBox" Grid.Row="2"
                  Content="Start with Windows" Margin="0,0,0,18"/>

        <!-- Save / Cancel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="70" Margin="0,0,8,0"
                    Padding="0,6" IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="70" Style="{StaticResource GhostButtonStyle}"
                    Padding="0,6" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
