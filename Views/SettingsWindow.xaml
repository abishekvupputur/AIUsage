<Window x:Class="CopilotUsage.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Usage - Settings"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- GitHub Authorization heading -->
        <TextBlock Grid.Row="0" Text="GitHub Authorization" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <!-- OAuth App Client ID -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GitHub OAuth App Client ID" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#6C757D" VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/settings/applications/new"
                               RequestNavigate="Hyperlink_RequestNavigate">Register app ↗</Hyperlink>
                </TextBlock>
            </Grid>
            <TextBox x:Name="ClientIdTextBox"
                     FontFamily="Consolas" FontSize="12"
                     Padding="6,4"/>
            <TextBlock TextWrapping="Wrap" Foreground="#6C757D" FontSize="11" Margin="0,4,0,0">
                Register an OAuth App on GitHub, set any Homepage/Callback URL, and enable
                <Bold>Device Flow</Bold>. Paste the Client ID here. The GitHub authorization
                page will then show your app name (e.g. "Copilot Usage") instead of "GitHub CLI".
            </TextBlock>
        </StackPanel>

        <!-- Authorization status panel -->
        <Border Grid.Row="2"
                Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1"
                CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>

                <!-- Status message -->
                <TextBlock x:Name="AuthStatusText"
                           Text="Not authorized. Enter a Client ID above, then click the button below."
                           TextWrapping="Wrap" Foreground="#495057" FontSize="12" Margin="0,0,0,8"/>

                <!-- Device code display (hidden until device flow starts) -->
                <Grid x:Name="CodePanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="White" BorderBrush="#CED4DA"
                            BorderThickness="1" CornerRadius="4" Padding="8,6">
                        <TextBlock x:Name="UserCodeText"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                   HorizontalAlignment="Center" Foreground="#0D6EFD"/>
                    </Border>
                    <Button Grid.Column="1" x:Name="CopyCodeButton"
                            Content="Copy" Width="64" Margin="8,0,0,0"
                            VerticalAlignment="Stretch"
                            Click="CopyCodeButton_Click"/>
                </Grid>

                <!-- Authorize / Re-authorize button -->
                <Button x:Name="AuthorizeButton"
                        Content="Authorize with GitHub..."
                        HorizontalAlignment="Left" Padding="12,6"
                        Click="AuthorizeButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Separator Grid.Row="3" Margin="0,0,0,12"/>

        <!-- Refresh interval -->
        <TextBlock Grid.Row="4" Text="Refresh Interval" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <ComboBox x:Name="IntervalCombo" Grid.Row="5"
                  Width="160" HorizontalAlignment="Left" Margin="0,0,0,12">
            <ComboBoxItem Content="1 minute"   Tag="1"/>
            <ComboBoxItem Content="5 minutes"  Tag="5"/>
            <ComboBoxItem Content="15 minutes" Tag="15"/>
            <ComboBoxItem Content="60 minutes" Tag="60"/>
        </ComboBox>

        <!-- Start with Windows -->
        <CheckBox x:Name="StartupCheckBox" Grid.Row="6"
                  Content="Start with Windows" Margin="0,0,0,16"/>

        <!-- Save / Cancel buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"   Width="70" Margin="0,0,8,0"
                    Padding="0,6" IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="70"
                    Padding="0,6" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
