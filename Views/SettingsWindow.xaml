<Window x:Class="CopilotUsage.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Usage - Settings"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#1A1A1A"
        Foreground="#EBEBEB">

    <Window.Resources>
        <!-- Dark TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="CaretBrush" Value="#D4845A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SelectionBrush" Value="#D4845A"/>
        </Style>
        <!-- Dark ComboBox with full template -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#252525"/>
                        <Setter Property="Foreground" Value="#EBEBEB"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3A2A1A"/>
                                <Setter Property="Foreground" Value="#D4845A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Right"
                                                  Width="22" Background="Transparent" BorderThickness="0"
                                                  Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                                </DockPanel>
                            </Border>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark CheckBox with custom template -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder"
                                    Width="14" Height="14"
                                    Background="#252525" BorderBrush="#555555" BorderThickness="1"
                                    CornerRadius="2" Margin="0,0,7,0" VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 2 6 L 5 10 L 12 2"
                                      Stroke="#D4845A" StrokeThickness="1.8"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D4845A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D4845A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Accent Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D4845A"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C07348"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A86038"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Ghost/secondary Button -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#EBEBEB"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" TextElement.FontFamily="Segoe UI">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Provider selector -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Provider" FontWeight="SemiBold" FontSize="13"
                       Foreground="#EBEBEB" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ClaudeRadio" Content="Claude AI"
                             Foreground="#EBEBEB" Margin="0,0,16,0"
                             Checked="Provider_Checked"/>
                <RadioButton x:Name="CopilotRadio" Content="GitHub Copilot"
                             Foreground="#EBEBEB"
                             Checked="Provider_Checked"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Claude auth panel ── -->
        <Border x:Name="ClaudePanel" Grid.Row="1"
                Background="#222222" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="6" Padding="14,12" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Claude Session Key" FontWeight="SemiBold"
                           FontSize="13" Foreground="#EBEBEB" Margin="0,0,0,10"/>

                <TextBlock Text="How to get your session key:" FontWeight="SemiBold"
                           FontSize="12" Foreground="#EBEBEB" Margin="0,0,0,6"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3">
                        <Run Text="1.  Open "/>
                        <Run Text="claude.ai" FontWeight="SemiBold" Foreground="#D4845A"/>
                        <Run Text=" in your browser and sign in"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3">
                        <Run Text="2.  Press "/>
                        <Run Text="F12" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                        <Run Text="  →  Application  →  Cookies  →  https://claude.ai"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,3">
                        <Run Text="3.  Find the row named "/>
                        <Run Text="sessionKey" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                        <Run Text=" and double-click its Value cell"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#888888">
                        <Run Text="4.  Press "/>
                        <Run Text="Ctrl+A" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                        <Run Text=" to select all, then "/>
                        <Run Text="Ctrl+C" FontFamily="Cascadia Code, Consolas" FontWeight="SemiBold" Foreground="#EBEBEB"/>
                        <Run Text=" to copy — the value is very long"/>
                    </TextBlock>
                </StackPanel>

                <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="Session Key:" FontSize="12" FontWeight="SemiBold"
                               Foreground="#EBEBEB" VerticalAlignment="Center"/>
                    <TextBlock x:Name="KeyLengthHint" DockPanel.Dock="Right"
                               FontSize="11" Foreground="#555555" VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </DockPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SessionKeyBox"
                             Grid.Column="0"
                             FontFamily="Cascadia Code, Consolas" FontSize="11"
                             Padding="7,6" Margin="0,0,8,0"
                             TextWrapping="NoWrap"
                             VerticalContentAlignment="Center"
                             MaxLength="4000"
                             TextChanged="SessionKeyBox_TextChanged"/>
                    <Button x:Name="TestButton"
                            Grid.Column="1"
                            Content="Test"
                            Width="70" Padding="0,6"
                            Click="TestButton_Click"/>
                </Grid>

                <TextBlock x:Name="AuthStatusText"
                           Text="" TextWrapping="Wrap"
                           FontSize="12" Margin="0,8,0,0"
                           Foreground="#888888"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- ── GitHub Copilot auth panel ── -->
        <Border x:Name="CopilotPanel" Grid.Row="1"
                Background="#222222" BorderBrush="#333333" BorderThickness="1"
                CornerRadius="6" Padding="14,12" Margin="0,0,0,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="GitHub Copilot Auth" FontWeight="SemiBold"
                           FontSize="13" Foreground="#EBEBEB" Margin="0,0,0,10"/>

                <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,12" TextWrapping="Wrap">
                    Sign in with GitHub to grant access to your Copilot usage data.
                    Click Connect and follow the instructions in your browser.
                </TextBlock>

                <!-- Connected state -->
                <StackPanel x:Name="CopilotConnectedPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <TextBlock x:Name="CopilotConnectedText" FontSize="12" Foreground="#3FB950"
                               Margin="0,0,0,8"/>
                    <Button x:Name="CopilotDisconnectButton" Content="Disconnect"
                            Width="110" HorizontalAlignment="Left" Padding="0,6"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="CopilotDisconnect_Click"/>
                </StackPanel>

                <!-- Device code flow -->
                <StackPanel x:Name="CopilotAuthFlowPanel">
                    <!-- Step 1: Connect button -->
                    <Button x:Name="CopilotConnectButton" Content="Connect GitHub Account"
                            Width="180" HorizontalAlignment="Left" Padding="0,6"
                            Click="CopilotConnect_Click"/>

                    <!-- Step 2: Device code display (shown while waiting) -->
                    <StackPanel x:Name="CopilotDeviceCodePanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <TextBlock FontSize="12" Foreground="#888888" Margin="0,0,0,6" TextWrapping="Wrap">
                            Open the URL below and enter the code to authorise:
                        </TextBlock>
                        <TextBlock x:Name="CopilotVerificationUrl" FontSize="12" Foreground="#D4845A"
                                   Margin="0,0,0,6" FontFamily="Cascadia Code, Consolas"/>
                        <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,4">Your code:</TextBlock>
                        <TextBlock x:Name="CopilotUserCode" FontSize="20" FontWeight="Bold"
                                   Foreground="#EBEBEB" FontFamily="Cascadia Code, Consolas"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="CopilotCancelButton" Content="Cancel"
                                Width="80" HorizontalAlignment="Left" Padding="0,6"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="CopilotCancel_Click"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="CopilotStatusText"
                           Text="" TextWrapping="Wrap"
                           FontSize="12" Margin="0,8,0,0"
                           Foreground="#888888"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Separator Grid.Row="2" Margin="0,0,0,14" Background="#2E2E2E" BorderBrush="#2E2E2E"/>

        <!-- Refresh interval -->
        <TextBlock Grid.Row="3" Text="Refresh Interval" FontWeight="SemiBold"
                   Foreground="#EBEBEB" Margin="0,0,0,6"/>
        <ComboBox x:Name="IntervalCombo" Grid.Row="4"
                  Width="160" HorizontalAlignment="Left" Margin="0,0,0,12">
            <ComboBoxItem Content="1 minute"   Tag="1"/>
            <ComboBoxItem Content="5 minutes"  Tag="5"/>
            <ComboBoxItem Content="15 minutes" Tag="15"/>
            <ComboBoxItem Content="60 minutes" Tag="60"/>
        </ComboBox>

        <!-- Start with Windows -->
        <CheckBox x:Name="StartupCheckBox" Grid.Row="5"
                  Content="Start with Windows" Margin="0,0,0,18"/>

        <!-- Save / Cancel buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="70" Margin="0,0,8,0"
                    Padding="0,6" IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="70" Style="{StaticResource GhostButtonStyle}"
                    Padding="0,6" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
