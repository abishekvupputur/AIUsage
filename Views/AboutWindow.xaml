<Window x:Class="CopilotUsage.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Copilot Usage"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <StackPanel Margin="24,20,24,20">

        <!-- Copilot icon rendered as WPF vector from the app's DrawingImage resource -->
        <Image Source="{StaticResource CopilotIcon}"
               Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <TextBlock Text="Copilot Usage" FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <TextBlock Text="Version 1.0" Foreground="#6C757D" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center"
                   Foreground="#495057" FontSize="12" Margin="0,0,0,12"
                   TextAlignment="Center">
            Shows your GitHub Copilot monthly premium
            request consumption in the system tray.
        </TextBlock>

        <TextBlock HorizontalAlignment="Center" Foreground="#495057" FontSize="12" Margin="0,0,0,4">
            Created by Tobias Wenzel
            <LineBreak/>
            <Hyperlink NavigateUri="mailto:tobias_wenzel@trimble.com"
                       RequestNavigate="Hyperlink_RequestNavigate">tobias_wenzel@trimble.com</Hyperlink>
        </TextBlock>

        <TextBlock HorizontalAlignment="Center" FontSize="12" Margin="0,0,0,20">
            <Hyperlink NavigateUri="https://github.com/TobiasW-T/CopilotUsage"
                       RequestNavigate="Hyperlink_RequestNavigate">github.com/TobiasW-T/CopilotUsage</Hyperlink>
        </TextBlock>

        <Button Content="OK" Width="80" HorizontalAlignment="Center" Padding="0,6"
                IsDefault="True" Click="OkButton_Click"/>

    </StackPanel>
</Window>
