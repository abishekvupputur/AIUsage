<Window x:Class="CopilotUsage.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About AI Usage"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#1A1A1A"
        Foreground="#EBEBEB">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D4845A"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C07348"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectableTextBlock" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Control}}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="CaretBrush" Value="Transparent"/>
            <Setter Property="SelectionBrush" Value="#D4845A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Background="Transparent" Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24,24,24,24" TextElement.FontFamily="Segoe UI">

        <!-- App icon (source set in code-behind) -->
        <Image x:Name="AppIcon"
               Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Text="AI Usage" FontSize="18" FontWeight="SemiBold"
                   Foreground="#EBEBEB" HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <TextBlock Text="Version 1.0" Foreground="#555555" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,14"/>

        <TextBox Style="{StaticResource SelectableTextBlock}"
                   HorizontalAlignment="Center"
                   Foreground="#888888" FontSize="12" Margin="0,0,0,14"
                   TextAlignment="Center">
            Shows quota usage for Claude, GitHub Copilot, OpenAI Codex, and Gemini
            in the system tray, refreshed automatically.
        </TextBox>

        <TextBlock HorizontalAlignment="Center" Foreground="#888888" FontSize="12" Margin="0,0,0,4">
            Created by TobiasW &amp; Abishek Narasimhan
        </TextBlock>

        <TextBlock HorizontalAlignment="Center" Foreground="#888888" FontSize="12" Margin="0,0,0,24">
            <Run Text="Forked from: "/>
            <Hyperlink NavigateUri="https://github.com/TobiasW-T/CopilotUsage"
                       Foreground="#D4845A"
                       RequestNavigate="Hyperlink_RequestNavigate">github.com/TobiasW-T/CopilotUsage</Hyperlink>
        </TextBlock>

        <Button Content="OK" Width="80" HorizontalAlignment="Center" Padding="0,6"
                IsDefault="True" Click="OkButton_Click"/>

    </StackPanel>
</Window>
